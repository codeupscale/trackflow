{
  "name": "trackflow-agent",
  "version": "1.0.33",
  "description": "TrackFlow Desktop Agent - Workforce Time Tracking & Monitoring",
  "main": "src/main/index.js",
  "author": {
    "name": "CodeUpScale",
    "email": "support@codeupscale.com"
  },
  "license": "UNLICENSED",
  "private": true,
  "homepage": "https://trackflow.codeupscale.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/codeupscale/trackflow.git"
  },
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron .",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac --x64 --arm64",
    "build:mac:x64": "electron-builder --mac --x64",
    "build:mac:arm64": "electron-builder --mac --arm64",
    "build:win": "electron-builder --win --x64",
    "build:win:ia32": "electron-builder --win --ia32",
    "build:linux": "electron-builder --linux --x64",
    "build:linux:arm64": "electron-builder --linux --arm64",
    "build:all": "electron-builder -mwl",
    "publish": "electron-builder --mac --win --linux --publish always",
    "publish:mac": "electron-builder --mac --x64 --arm64 --publish always",
    "publish:win": "electron-builder --win --x64 --publish always",
    "publish:linux": "electron-builder --linux --x64 --publish always",
    "release": "npm run test && npm run publish",
    "test": "jest --verbose",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "jest test/e2e/ --verbose",
    "dev:inspect": "NODE_ENV=development electron . --remote-debugging-port=9222",
    "icons": "node scripts/generate-icons.js",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.trackflow.agent",
    "productName": "TrackFlow",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "afterPack": "scripts/afterPack.js",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "!assets/icon-source.*",
      "!**/*.map",
      "!**/test/**",
      "!**/tests/**",
      "!**/docs/**"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**",
      "node_modules/sharp/**",
      "node_modules/uiohook-napi/**"
    ],
    "extraResources": [
      {
        "from": ".env",
        "to": ".env"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "darkModeSupport": true,
      "type": "distribution",
      "notarize": false,
      "identity": null,
      "extendInfo": {
        "NSScreenCaptureUsageDescription": "TrackFlow needs screen capture access to take periodic screenshots for time tracking.",
        "NSAppleEventsUsageDescription": "TrackFlow needs automation access to detect the active application name."
      }
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "publisherName": "CodeUpScale",
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "TrackFlow",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icons",
      "category": "Utility",
      "synopsis": "Time tracking and workforce monitoring agent",
      "description": "TrackFlow Desktop Agent for employee time tracking, activity monitoring, and screenshot capture.",
      "desktop": {
        "StartupNotify": "true",
        "Terminal": "false",
        "Type": "Application",
        "Categories": "Utility;Office;"
      },
      "maintainer": "CodeUpScale <support@codeupscale.com>"
    },
    "appImage": {
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "codeupscale",
      "repo": "trackflow",
      "releaseType": "release"
    }
  },
  "dependencies": {
    "axios": "^1.6.0",
    "better-sqlite3": "^11.0.0",
    "electron-updater": "^6.1.0",
    "form-data": "^4.0.0",
    "posthog-node": "^5.28.5",
    "sharp": "^0.33.0",
    "uiohook-napi": "^1.5.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "electron": "^28.3.3",
    "electron-builder": "^24.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0"
  }
}

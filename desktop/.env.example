# TrackFlow Desktop — Environment Variables
# ──────────────────────────────────────────
# Copy this to .env and fill in the values.
# For packaged builds, these are baked in by the desktop-release.yml workflow
# via GitHub Actions secrets. For dev mode, create desktop/.env manually.
#
# IMPORTANT: desktop/.env must NOT be committed — it contains secrets.

# API endpoint (defaults to production if not set)
TRACKFLOW_API_URL=https://trackflow.codeupscale.com/api/v1
TRACKFLOW_WEB_URL=https://trackflow.codeupscale.com

# Google OAuth — MUST use the DESKTOP (Installed Application) client ID.
# This is NOT the web client ID (545920400773-...).
# The desktop client ID must match GOOGLE_DESKTOP_CLIENT_ID in backend/.env.
# Get it from Google Cloud Console → APIs & Services → Credentials → Desktop client.
TRACKFLOW_GOOGLE_CLIENT_ID=137280944029-v0om6adqfmkvnds0ises3ud8vidpecre.apps.googleusercontent.com
TRACKFLOW_GOOGLE_CLIENT_SECRET=<your_desktop_oauth_client_secret>

# Analytics (optional)
POSTHOG_KEY=
POSTHOG_HOST=https://us.i.posthog.com

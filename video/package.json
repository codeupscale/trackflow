{
  "name": "trackflow-video",
  "version": "1.0.0",
  "private": true,
  "description": "TrackFlow product demo video built with Remotion",
  "scripts": {
    "studio": "remotion studio",
    "render": "remotion render TrackFlowDemo out/trackflow-demo.mp4",
